.layer-mob-thumb canvas{width:100%;height:100%}
.layer-mob-name{flex:1;font-size:13px}
.layer-mob-vis{font-size:18px;cursor:pointer;padding:4px}
.layer-mob-del{font-size:16px;color:var(--accent2);cursor:pointer;padding:4px}
.layer-actions-mob{display:flex;gap:8px;margin-top:10px}
.layer-action-mob{flex:1;padding:10px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text2);cursor:pointer;font-size:13px;text-align:center}
.layer-action-mob:active{background:var(--hover)}

/* Filters grid */
.filter-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.filter-mob-btn{padding:12px 8px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text2);cursor:pointer;font-size:13px;text-align:center;display:flex;align-items:center;gap:8px}
.filter-mob-btn:active{background:var(--hover);transform:scale(.96)}

/* Zoom indicator */
#zoom-badge{
  position:fixed;left:14px;bottom:calc(var(--bottombar) + 14px);
