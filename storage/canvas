/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;display:none;align-items:flex-end;justify-content:center}
.modal-overlay.show{display:flex}
.modal-sheet{background:var(--panel);border-radius:20px 20px 0 0;padding:20px 20px calc(20px + var(--safe-bottom));width:100%}
.modal-sheet h3{font-size:16px;font-weight:600;margin-bottom:16px}
.modal-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.modal-row label{font-size:13px;color:var(--text2);width:80px}
.modal-row input,.modal-row select{flex:1;padding:10px;background:var(--panel2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:14px;font-family:'Outfit',sans-serif}
.modal-actions{display:flex;gap:10px;margin-top:16px}
.btn{flex:1;padding:13px;border-radius:12px;cursor:pointer;font-size:14px;font-weight:600;border:none;font-family:'Outfit',sans-serif;text-align:center}
.btn-primary{background:var(--accent);color:#fff}
.btn-secondary{background:var(--panel2);color:var(--text2);border:1px solid var(--border)}

/* Toast */
#toast{
  position:fixed;top:calc(var(--topbar)+12px);left:50%;transform:translateX(-50%);
  background:var(--panel2);border:1px solid var(--border);border-radius:10px;
  padding:8px 18px;font-size:13px;color:var(--text);z-index:999;
  opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;
}
#toast.show{opacity:1}

/* Pinch hint */
#pinch-hint{position:fixed;bottom:calc(var(--bottombar)+80px);left:50%;transform:translateX(-50%);background:rgba(108,99,255,.85);color:#fff;font-size:12px;padding:6px 14px;border-radius:20px;z-index:89;opacity:0;transition:opacity .5s;pointer-events:none}

::-webkit-scrollbar{display:none}
</style>
</head>
