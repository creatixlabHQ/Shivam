      <div class="gbtn" id="txt-italic" onclick="toggleTextItalic()" style="font-style:italic">I Italic</div>
      <div class="gbtn" id="txt-under" onclick="toggleTextUnder()" style="text-decoration:underline">U Under</div>
    </div>
  </div>
</div>

