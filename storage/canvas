  <div class="panel-header">
    <h3>🎨 Colors</h3>
    <div class="panel-close" onclick="closeAllPanels()">✕</div>
  </div>
  <div class="panel-body">
    <div class="cur-colors-row">
      <div>
        <div style="font-size:10px;color:var(--text2);margin-bottom:4px">Foreground</div>
        <div id="fg-color" onclick="document.getElementById('fg-picker').click()"></div>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text2);margin-bottom:4px">Background</div>
