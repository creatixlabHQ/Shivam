    <div style="margin-bottom:10px;font-size:12px;color:var(--text2)">Line Style</div>
    <div class="grid-btns" style="grid-template-columns:repeat(3,1fr)">
      <div class="gbtn active" id="ls-solid" onclick="setLineDash('solid')">— Solid</div>
      <div class="gbtn" id="ls-dashed" onclick="setLineDash('dashed')">- - Dash</div>
      <div class="gbtn" id="ls-dotted" onclick="setLineDash('dotted')">··· Dot</div>
