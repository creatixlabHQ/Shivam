  display:flex;align-items:center;justify-content:center;
  font-size:20px;cursor:pointer;transition:all .2s;
  box-shadow:0 4px 16px rgba(0,0,0,.4);border:none;
}
.fab:active{transform:scale(.88)}
#fab-undo{background:var(--panel2);color:var(--text2);border:1px solid var(--border)}
#fab-redo{background:var(--panel2);color:var(--text2);border:1px solid var(--border)}
#fab-color{background:var(--accent);color:#fff;width:52px;height:52px}

/* ===== SLIDE-UP PANELS ===== */
.panel-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;
  display:none;opacity:0;transition:opacity .25s;
}
.panel-overlay.show{display:block;opacity:1}
.slide-panel{
  position:fixed;left:0;right:0;bottom:0;z-index:201;
  background:var(--panel);border-radius:20px 20px 0 0;
  border-top:1px solid var(--border);
  transform:translateY(100%);transition:transform .3s cubic-bezier(.32,.72,0,1);
  max-height:85vh;overflow-y:auto;padding-bottom:calc(20px + var(--safe-bottom));
}
.slide-panel.show{transform:translateY(0)}
.panel-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:12px auto 4px}
.panel-header{padding:8px 20px 16px;display:flex;align-items:center;justify-content:space-between}
.panel-header h3{font-size:16px;font-weight:600}
.panel-close{font-size:20px;color:var(--text2);cursor:pointer;padding:4px}
.panel-body{padding:0 16px 16px}

/* Color panel */
#color-grid-mob{display:grid;grid-template-columns:repeat(8,1fr);gap:5px;margin-bottom:14px}
.color-swatch{width:100%;aspect-ratio:1;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:transform .1s}
.color-swatch:active{transform:scale(.85)}
.color-swatch.active{border-color:#fff}
.cur-colors-row{display:flex;align-items:center;gap:12px;margin-bottom:16px}
#fg-color,#bg-color{width:44px;height:44px;border-radius:10px;border:2px solid var(--border);cursor:pointer}
.swap-btn{padding:8px 14px;background:var(--panel2);border:1px solid var(--border);border-radius:8px;color:var(--text2);font-size:13px;cursor:pointer}
.swap-btn:active{background:var(--hover)}
#custom-color-mob{width:100%;height:36px;border:1px solid var(--border);border-radius:8px;cursor:pointer;margin-top:4px}

/* Brush panel sliders */
.slider-group{margin-bottom:16px}
.slider-group label{font-size:12px;color:var(--text2);display:flex;justify-content:space-between;margin-bottom:6px}
.slider-group label span{color:var(--accent);font-weight:600}
.slider-group input[type=range]{width:100%;height:6px;-webkit-appearance:none;border-radius:3px;background:var(--border);outline:none}
.slider-group input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:pointer;border:3px solid var(--panel)}

/* Grid buttons */
.grid-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px}
.gbtn{padding:12px 6px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text2);cursor:pointer;font-size:13px;text-align:center;transition:all .15s}
.gbtn:active{transform:scale(.92)}
.gbtn.active{background:var(--active);color:var(--accent);border-color:var(--accent)}

/* Select boxes */
select.mob-select{width:100%;padding:10px 12px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:14px;margin-bottom:10px;font-family:'Outfit',sans-serif}

/* Layers */
.layer-mob{display:flex;align-items:center;gap:10px;padding:10px 12px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;margin-bottom:6px}
.layer-mob.active{border-color:var(--accent);background:var(--active)}
.layer-mob-thumb{width:36px;height:28px;border-radius:5px;background:repeating-conic-gradient(#333 0% 25%,#222 0% 50%) 0 0/8px 8px;border:1px solid var(--border);overflow:hidden;flex-shrink:0}
.layer-mob-thumb canvas{width:100%;height:100%}
.layer-mob-name{flex:1;font-size:13px}
.layer-mob-vis{font-size:18px;cursor:pointer;padding:4px}
.layer-mob-del{font-size:16px;color:var(--accent2);cursor:pointer;padding:4px}
.layer-actions-mob{display:flex;gap:8px;margin-top:10px}
.layer-action-mob{flex:1;padding:10px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text2);cursor:pointer;font-size:13px;text-align:center}
.layer-action-mob:active{background:var(--hover)}

/* Filters grid */
.filter-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.filter-mob-btn{padding:12px 8px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text2);cursor:pointer;font-size:13px;text-align:center;display:flex;align-items:center;gap:8px}
.filter-mob-btn:active{background:var(--hover);transform:scale(.96)}

/* Zoom indicator */
#zoom-badge{
  position:fixed;left:14px;bottom:calc(var(--bottombar) + 14px);
  background:var(--panel2);border:1px solid var(--border);
  border-radius:8px;padding:6px 10px;font-size:12px;color:var(--text2);
  z-index:90;font-weight:600;
}

/* More menu */
.more-menu{
  position:fixed;bottom:calc(var(--bottombar)+8px);right:72px;
  background:var(--panel);border:1px solid var(--border);border-radius:14px;
  padding:6px;z-index:300;display:none;min-width:180px;
  box-shadow:0 8px 32px rgba(0,0,0,.5);
}
.more-menu.show{display:block}
.more-item{padding:11px 16px;border-radius:8px;cursor:pointer;font-size:14px;color:var(--text2);display:flex;align-items:center;gap:10px}
.more-item:active{background:var(--hover);color:var(--text)}

/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:500;display:none;align-items:flex-end;justify-content:center}
.modal-overlay.show{display:flex}
.modal-sheet{background:var(--panel);border-radius:20px 20px 0 0;padding:20px 20px calc(20px + var(--safe-bottom));width:100%}
.modal-sheet h3{font-size:16px;font-weight:600;margin-bottom:16px}
.modal-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.modal-row label{font-size:13px;color:var(--text2);width:80px}
.modal-row input,.modal-row select{flex:1;padding:10px;background:var(--panel2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:14px;font-family:'Outfit',sans-serif}
.modal-actions{display:flex;gap:10px;margin-top:16px}
.btn{flex:1;padding:13px;border-radius:12px;cursor:pointer;font-size:14px;font-weight:600;border:none;font-family:'Outfit',sans-serif;text-align:center}
.btn-primary{background:var(--accent);color:#fff}
.btn-secondary{background:var(--panel2);color:var(--text2);border:1px solid var(--border)}

/* Toast */
#toast{
  position:fixed;top:calc(var(--topbar)+12px);left:50%;transform:translateX(-50%);
  background:var(--panel2);border:1px solid var(--border);border-radius:10px;
  padding:8px 18px;font-size:13px;color:var(--text);z-index:999;
  opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;
}
#toast.show{opacity:1}

/* Pinch hint */
#pinch-hint{position:fixed;bottom:calc(var(--bottombar)+80px);left:50%;transform:translateX(-50%);background:rgba(108,99,255,.85);color:#fff;font-size:12px;padding:6px 14px;border-radius:20px;z-index:89;opacity:0;transition:opacity .5s;pointer-events:none}

::-webkit-scrollbar{display:none}
</style>
</head>
<body>

<!-- Top Bar -->
<div id="topbar">
  <div id="app-title">CanvasPro</div>
  <div class="top-btn" onclick="showPanel('layers-panel')" title="Layers">🗂️</div>
  <div class="top-btn" onclick="showPanel('filters-panel')" title="Filters">✨</div>
  <div class="top-btn" onclick="toggleMoreMenu()" id="more-btn">⋯</div>
  <div class="top-btn accent" onclick="exportImage()">Save</div>
</div>

<!-- Canvas -->
<div id="canvas-container">
  <div id="canvas-wrapper">
    <canvas id="canvas-bg"></canvas>
    <canvas id="canvas-main"></canvas>
    <canvas id="canvas-overlay"></canvas>
    <div id="text-input-container"><div id="text-input" contenteditable="true" spellcheck="false"></div></div>
    <div id="selection-box"></div>
  </div>
</div>

<!-- FABs -->
<div id="fab-row">
  <div class="fab" id="fab-redo" onclick="redoAction()">↪</div>
  <div class="fab" id="fab-undo" onclick="undoAction()">↩</div>
  <div class="fab" id="fab-color" onclick="showPanel('color-panel')">🎨</div>
</div>

<!-- Zoom Badge -->
<div id="zoom-badge">100%</div>

<!-- Bottom Toolbar -->
<div id="bottombar">
  <div class="tool-btn active" id="t-pen" onclick="setTool('pen')">✏️<span>Pen</span></div>
  <div class="tool-btn" id="t-brush" onclick="setTool('brush')">🖌️<span>Brush</span></div>
  <div class="tool-btn" id="t-eraser" onclick="setTool('eraser')">🧹<span>Erase</span></div>
  <div class="tool-btn" id="t-fill" onclick="setTool('fill')">🪣<span>Fill</span></div>
  <div class="tool-sep-v"></div>
  <div class="tool-btn" id="t-line" onclick="setTool('line')">╱<span>Line</span></div>
  <div class="tool-btn" id="t-rect" onclick="setTool('rect')">⬜<span>Rect</span></div>
  <div class="tool-btn" id="t-ellipse" onclick="setTool('ellipse')">⭕<span>Oval</span></div>
  <div class="tool-btn" id="t-triangle" onclick="setTool('triangle')">△<span>Tri</span></div>
  <div class="tool-btn" id="t-arrow" onclick="setTool('arrow')">→<span>Arrow</span></div>
  <div class="tool-btn" id="t-star" onclick="setTool('star')">⭐<span>Star</span></div>
  <div class="tool-sep-v"></div>
  <div class="tool-btn" id="t-text" onclick="setTool('text')">T<span>Text</span></div>
  <div class="tool-btn" id="t-eyedrop" onclick="setTool('eyedrop')">💉<span>Pick</span></div>
  <div class="tool-btn" id="t-select" onclick="setTool('select')">⬚<span>Select</span></div>
  <div class="tool-sep-v"></div>
  <div class="tool-btn" onclick="showPanel('brush-panel')">⚙️<span>Options</span></div>
</div>

<!-- More Menu -->
<div class="more-menu" id="more-menu">
  <div class="more-item" onclick="showNew();closeMoreMenu()">📄 New Canvas</div>
  <div class="more-item" onclick="openFile();closeMoreMenu()">📂 Open Image</div>
  <div class="more-item" onclick="selectAll();closeMoreMenu()">⬜ Select All</div>
  <div class="more-item" onclick="clearCanvas();closeMoreMenu()">🗑️ Clear Layer</div>
  <div class="more-item" onclick="flipH();closeMoreMenu()">↔️ Flip H</div>
  <div class="more-item" onclick="flipV();closeMoreMenu()">↕️ Flip V</div>
  <div class="more-item" onclick="rotateCanvas();closeMoreMenu()">🔄 Rotate 90°</div>
</div>

<!-- Panel Overlay -->
<div class="panel-overlay" id="panel-overlay" onclick="closeAllPanels()"></div>

<!-- COLOR PANEL -->
<div class="slide-panel" id="color-panel">
  <div class="panel-handle"></div>
  <div class="panel-header">
    <h3>🎨 Colors</h3>
    <div class="panel-close" onclick="closeAllPanels()">✕</div>
  </div>
  <div class="panel-body">
    <div class="cur-colors-row">
      <div>
        <div style="font-size:10px;color:var(--text2);margin-bottom:4px">Foreground</div>
        <div id="fg-color" onclick="document.getElementById('fg-picker').click()"></div>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text2);margin-bottom:4px">Background</div>
        <div id="bg-color" onclick="document.getElementById('bg-picker').click()"></div>
      </div>
      <div class="swap-btn" onclick="swapColors()">⇆ Swap</div>
    </div>
    <input type="color" id="fg-picker" style="display:none" oninput="setFgColor(this.value)">
    <input type="color" id="bg-picker" style="display:none" oninput="setBgColor(this.value)">
    <div id="color-grid-mob"></div>
    <input type="color" id="custom-color-mob" title="Custom" oninput="setFgColor(this.value)">
  </div>
</div>

<!-- BRUSH PANEL -->
<div class="slide-panel" id="brush-panel">
  <div class="panel-handle"></div>
  <div class="panel-header">
    <h3>⚙️ Brush & Shape Options</h3>
    <div class="panel-close" onclick="closeAllPanels()">✕</div>
  </div>
  <div class="panel-body">
    <div class="slider-group">
      <label>Size <span id="bsv">5</span>px</label>
      <input type="range" id="brush-size" min="1" max="100" value="5" oninput="updateBrush()">
    </div>
    <div class="slider-group">
      <label>Opacity <span id="bov">100</span>%</label>
      <input type="range" id="brush-opacity" min="1" max="100" value="100" oninput="updateBrush()">
    </div>
    <div class="slider-group">
      <label>Hardness <span id="bhv">80</span>%</label>
      <input type="range" id="brush-hardness" min="0" max="100" value="80" oninput="updateBrush()">
    </div>
    <div style="margin-bottom:10px;font-size:12px;color:var(--text2)">Blend Mode</div>
    <select id="blend-mode" class="mob-select" onchange="updateBlend()">
      <option value="source-over">Normal</option><option value="multiply">Multiply</option>
      <option value="screen">Screen</option><option value="overlay">Overlay</option>
      <option value="darken">Darken</option><option value="lighten">Lighten</option>
      <option value="color-dodge">Color Dodge</option><option value="color-burn">Color Burn</option>
      <option value="difference">Difference</option><option value="exclusion">Exclusion</option>
    </select>
    <div style="margin-bottom:10px;font-size:12px;color:var(--text2)">Shape Style</div>
    <div class="grid-btns" style="grid-template-columns:repeat(3,1fr)">
      <div class="gbtn active" id="shape-stroke" onclick="setShapeStyle('stroke')">⬡ Stroke</div>
      <div class="gbtn" id="shape-fill" onclick="setShapeStyle('fill')">⬢ Fill</div>
      <div class="gbtn" id="shape-both" onclick="setShapeStyle('both')">◼ Both</div>
    </div>
    <div class="slider-group">
      <label>Stroke W <span id="swv">2</span>px</label>
      <input type="range" id="stroke-width" min="1" max="30" value="2" oninput="updateStroke()">
    </div>
    <div style="margin-bottom:10px;font-size:12px;color:var(--text2)">Line Style</div>
    <div class="grid-btns" style="grid-template-columns:repeat(3,1fr)">
      <div class="gbtn active" id="ls-solid" onclick="setLineDash('solid')">— Solid</div>
      <div class="gbtn" id="ls-dashed" onclick="setLineDash('dashed')">- - Dash</div>
      <div class="gbtn" id="ls-dotted" onclick="setLineDash('dotted')">··· Dot</div>
    </div>
    <div style="margin-bottom:10px;font-size:12px;color:var(--text2)">Text Settings</div>
    <div class="slider-group">
      <label>Font Size <span id="fsv">20</span>px</label>
      <input type="range" id="font-size-slider" min="8" max="120" value="20" oninput="updateTextStyle()">
    </div>
    <select id="font-family" class="mob-select" onchange="updateTextStyle()">
      <option>Arial</option><option>Georgia</option><option>Courier New</option>
      <option>Times New Roman</option><option>Verdana</option><option>Impact</option>
      <option>Comic Sans MS</option><option selected>Outfit</option>
    </select>
    <div class="grid-btns" style="grid-template-columns:repeat(3,1fr)">
      <div class="gbtn" id="txt-bold" onclick="toggleTextBold()" style="font-weight:700">B Bold</div>
      <div class="gbtn" id="txt-italic" onclick="toggleTextItalic()" style="font-style:italic">I Italic</div>
      <div class="gbtn" id="txt-under" onclick="toggleTextUnder()" style="text-decoration:underline">U Under</div>
    </div>
  </div>
</div>

<!-- LAYERS PANEL -->
<div class="slide-panel" id="layers-panel">
  <div class="panel-handle"></div>
  <div class="panel-header">
    <h3>🗂️ Layers</h3>
    <div class="panel-close" onclick="closeAllPanels()">✕</div>
  </div>
  <div class="panel-body">
    <div id="layers-list-mob"></div>
    <div class="layer-actions-mob">
      <div class="layer-action-mob" onclick="addLayer()">+ Add</div>
      <div class="layer-action-mob" onclick="duplicateLayer()">⧉ Dup</div>
      <div class="layer-action-mob" onclick="mergeDown()">↓ Merge</div>
      <div class="layer-action-mob" onclick="deleteLayer()">✕ Del</div>
    </div>
  </div>
</div>

<!-- FILTERS PANEL -->
<div class="slide-panel" id="filters-panel">
  <div class="panel-handl