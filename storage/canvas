/* Grid buttons */
.grid-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px}
.gbtn{padding:12px 6px;background:var(--panel2);border:1px solid var(--border);border-radius:10px;color:var(--text2);cursor:pointer;font-size:13px;text-align:center;transition:all .15s}
