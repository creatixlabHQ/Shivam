    <input type="color" id="bg-picker" style="display:none" oninput="setBgColor(this.value)">
    <div id="color-grid-mob"></div>
    <input type="color" id="custom-color-mob" title="Custom" oninput="setFgColor(this.value)">
  </div>
</div>

<!-- BRUSH PANEL -->
<div class="slide-panel" id="brush-panel">
